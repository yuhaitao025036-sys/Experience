default_prompt_for_recurrent_grad_input := Import[{future_tensor function recurrent_backward.viba}].default_prompt_for_recurrent_grad_input
BackwardPromptCallable := Import[{future_tensor function recurrent_backward.viba}].BackwardPromptCallable

FtRecurrent := torch.autograd.Function[
    $forward Import[{future_tensor function recurrent_forward.viba}],
    $backward Import[{future_tensor function recurrent_backward.viba}],
    # ctx saves backward args
    $ctx.topk_self_confidence_but_failed int # default 8
    $ctx.grad_input_prompt BackwardPromptCallable # default None
    $ctx.task_prompt str # default ""
    $ctx.llm_method str # default "raw_llm_api"
    $ctx.llm_env dict[str, str] # default None
]

ft_recurrent := FtRecurrent.apply
