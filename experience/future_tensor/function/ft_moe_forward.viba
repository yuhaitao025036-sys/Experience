
# Async FutureTensor version of st_moe_forward.
#
# Parameter mapping:
#   st_moe.input      <=> ft_moe.input (direct, FutureTensor, requires_grad)
#   st_moe.context    <=> ft_moe.prompt (from upstream ft_async_get, requires_grad=False)
#   st_moe.experience <=> ft_moe.experience (direct)
#
# The output is a FutureTensor whose ft_async_get:
#   1. Takes (coordinates, prompt) from upstream
#   2. If input is not None, reads input[coordinates] content as st_moe.input
#   3. Uses prompt as st_moe.context (requires_grad=False)
#   4. Runs MoE: query, select topk, workspace, LLM
#   5. Returns (output_content, Status)

ft_moe_forward :=
    ($output FutureTensor[$shape],
     $prompt_tensor FutureTensor[$shape],
     $selected_experience_qkv_indexes_map dict)
    <- $input FutureTensor  # maybe none symbolic tensor; for chaining. requires_grad flows through
    <- $experience ExperienceTensor[Symbolic[torch.Tensor]]
    <- $output_prompt OutputPromptCallable # default None
    <- $query_prompt QueryPromptCallable # default None
    <- $task_prompt str # default ""
    <- $topk int # default 16
    <- $retrieval_method RetrievalMethodCallable # default None
    <- $llm_method ("coding_agent" | "raw_llm_api") # default raw_llm_api
    <- $llm_env dict[str, str] # default None
    # inline
    <- ($shape <- $input.shape)
    <- { prompt_tensor = future tensor of none_like(input) }
    <- { selected_experience_qkv_indexes_map = {} }
    <- $output.ft_async_get ft_moe_forward_async_get

ft_moe_forward_async_get :=
    Awaitable[(str, Status)]
    <- $coordinates list[int]
    <- $prompt str  # from upstream ft_async_get => becomes st_moe.context
    # captured args
    <- $input FutureTensor  # maybe None; = st_moe.input
    <- $experience ExperienceTensor[Symbolic[torch.Tensor]]
    <- $prompt_tensor FutureTensor
    <- $selected_experience_qkv_indexes_map dict
    <- $output_prompt OutputPromptCallable
    <- $query_prompt QueryPromptCallable
    <- $task_prompt str
    <- $topk int
    <- $retrieval_method RetrievalMethodCallable
    <- $llm_method str
    <- $llm_env dict[str, str]
    # inline
    # 1. Store the raw prompt into prompt_tensor for reference
    <- { prompt_tensor.st_setitem(coordinates, prompt) }
    # 2. Build scalar_input from input[coordinates] (= st_moe.input)
    <- ($input_content str <- {
        if input.data[coordinates] > 0:
            read input content at coordinates
        else:
            ""
    })
    <- ($scalar_input Symbolic[torch.Tensor]
        <- Import[symbolic_tensor make_tensor]
        <- [input_content] if input_content else ["TODO"])
    # 3. Build scalar_context from prompt (= st_moe.context, requires_grad=False)
    <- ($scalar_context Symbolic[torch.Tensor]
        <- Import[symbolic_tensor make_tensor]
        <- [prompt])
    # 4. Get query from scalar_input
    <- ($input_query
        <- Import[symbolic_tensor function get_query_tensor]
        <- $scalar_input
        <- $query_prompt
        <- $task_prompt
        <- $llm_method
        <- $llm_env)
    # 5. Select topk experience entries
    <- ($select_experience_query_indexes list[torch.Tensor[int]]
        <- Import[symbolic_tensor function select_qkv_indexes]
        <- $experience
        <- $input_query
        <- $topk
        <- $retrieval_method)
    <- { selected_experience_qkv_indexes_map[tuple(coordinates)] = select_experience_query_indexes }
    <- ($select_experience_indexes <- replace_last_tensor_with_full_slice <- $select_experience_query_indexes)
    # 6. Build workspace for LLM
    <- $slice_view Import[symbolic_tensor tensor_util slice_view]
    <- $dump_view Import[symbolic_tensor tensor_util dump_view]
    <- ($experience_sliced_view
        <- $slice_view
        <- $experience
        <- $select_experience_indexes)
    <- ($scalar_output Symbolic[torch.Tensor]
        <- Import[symbolic_tensor tensor_util todo_tensor_like]
        <- $scalar_input)
    <- ($workspace_dir <- TemporaryDirectory)
    <- (void <- $dump_view <- $experience_sliced_view <- f"{workspace_dir}/const_experiance_view")
    <- (void <- $dump_view <- $scalar_input <- f"{workspace_dir}/const_input_view")
    # context: dump alongside input (prompt as context)
    <- (void <- $dump_view <- $scalar_context <- f"{workspace_dir}/const_context_view")
    <- (void <- $dump_view <- $scalar_output <- f"{workspace_dir}/mutable_output_dir")
    # 7. Build prompt and run LLM
    <- ($prompt_str <- ($output_prompt | default_prompt_for_output)
        <- $task_prompt
        <- $workspace_dir
        <- f"{workspace_dir}/const_experiance_view"
        <- f"{workspace_dir}/const_input_view"
        <- f"{workspace_dir}/mutable_output_dir")
    <- ($agent_task AgentTask <- $workspace_dir <- "mutable_output_dir" <- $prompt_str)
    <- (void <- Import[llm_client task_handler] <- [$agent_task] <- $llm_method <- $llm_env)
    # 8. Read output and determine status
    <- ($output_content str <- read_storage <- $scalar_output <- 0)
    <- ($status Status <- { confidence(1.0) if output_content != "TODO" else self_confidence_but_failed(0.5) })
    <- return ($output_content, $status)

OutputPromptCallable := $func ($ret str <- $task_prompt str <- $workspace_dir str <- $const_experience_view str <- $const_input_view str <- $mutable_output_dir str)
QueryPromptCallable := Import[{symbolic_tensor function get_query_tensor.viba}].QueryPromptCallable
RetrievalMethodCallable := Import[{symbolic_tensor function select_qkv_indexes.viba}].RetrievalMethodCallable
AgentTask := Import[{llm_client agent_task.viba}]
Status := Import[{future_tensor status.viba}].Status
