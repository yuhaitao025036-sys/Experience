tag_list_edit_distance :=
    # edit distance ratio between two list[str] (predicted vs ground truth member_tags)
    # uses Levenshtein on the sequence of tags, not on characters within tags
    # ratio = edit_distance / max(len(predicted), len(expected), 1)
    # 0.0 = identical, 1.0 = completely different
    float
    <- $predicted list[str]
    <- $expected list[str]
    # inline
    <- { Levenshtein distance on the two lists, treating each tag as an atomic token }
