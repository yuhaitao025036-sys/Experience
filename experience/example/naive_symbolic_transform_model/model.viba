OutputPromptCallable := Import[experience/symbolic_tensor/function/symbolic_transform.viba].OutputPromptCallable
QueryPromptCallable := Import[experience/symbolic_tensor/function/symbolic_transform.viba].QueryPromptCallable
BackwardPromptCallable := Import[experience/symbolic_tensor/function/symbolic_transform.viba].BackwardPromptCallable
RetrievalMethodCallable := Import[experience/symbolic_tensor/function/symbolic_transform.viba].RetrievalMethodCallable

NaiveModel := torch.nn.Module

__init__ :=
    void
    <- $self NaiveModel
    <- $output_prompt OutputPromptCallable # default None
    <- $query_prompt QueryPromptCallable # default None
    <- $grad_input_prompt BackwardPromptCallable # default None
    <- $grad_exp_key_prompt BackwardPromptCallable # default None
    <- $grad_exp_value_prompt BackwardPromptCallable # default None
    <- $task_prompt str # default ""
    <- $topk int # default 16
    <- $retrieval_method RetrievalMethodCallable # default None
    <- $llm_env dict[str, str] # default None
    # inline
    <- Import[experience/symbolic_tensor/module/symbolic_transform.py]

forward := ...
