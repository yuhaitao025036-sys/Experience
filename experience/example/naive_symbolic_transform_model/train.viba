OutputPromptCallable := Import[experience/symbolic_tensor/function/st_moe.viba].OutputPromptCallable
RetrievalMethodCallable := Import[experience/symbolic_tensor/function/st_moe.viba].RetrievalMethodCallable

auto_train :=
    ($losses list[float], dict[$log_type str, $log_content str])
    <- $num_experience int # default 24
    <- $topk int # default 1
    <- $forward_prompt OutputPromptCallable # default None
    <- $lr float # default 1.0
    <- $llm_model str # default None
    <- $retrieval_method RetrievalMethodCallable # default None
    <- $num_iterations int # default 5
    <- $batch_size int # default 12
    # inline
    <- Import[experience/example/naive_symbolic_transform_model/model.py].NaiveModel
    <- $task_prompt "Translate Python To Viba"
    <- Import[experience/symbolic_tensor/function/get_edit_distance_ratio.py]
    <- Import[experience/symbolic_tensor/optimizer/st_sgd.py]
    # NaiveModel(forward_prompt, task_prompt, topk, retrieval_method, llm_env)
    # llm_env built from llm_model if not None
    # training loop with batch slicing
    # returns (losses, logs_dict)
