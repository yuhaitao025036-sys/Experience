
# StSGD extends torch.optim.Optimizer
# Two-channel update: numeric coefficient SGD + symbolic text diff via LLM
#
# Usage:
#   optimizer = StSGD([experience_tensor], lr=0.01)
#   optimizer.zero_grad()
#   ... forward / backward ...
#   optimizer.step()

StSGD := torch.optim.Optimizer

__init__ :=
    void
    <- $self StSGD
    <- $params ParamsT
    <- $lr float # default 0.01
    <- $llm_env dict[str, str] # default None
    # inline
    <- (void <- super().__init__ <- $params <- dict[lr=$lr])

step :=
    void
    <- $self StSGD
    <- $closure Optional[Callable] # default None
    # inline
    <- $slice_view Import[experience/symbolic_tensor/tensor_util/slice_view.viba]
    <- $slice_tensor Import[experience/symbolic_tensor/tensor_util/slice_tensor.viba]
    <- $dump_view Import[experience/symbolic_tensor/tensor_util/dump_view.viba]

    # for each param_group, for each param with grad:
    <- ($lr float <- $param_group['lr'])
    <- (ParamList[$param Symbolic[torch.Tensor]] <- $param_group['params'])
    <- (ParamList[$grad Symbolic[torch.Tensor]] <- $param.grad)

    <- ($raw_selected_param_points <- nonzero <- $param.grad)
    <- ($kv_points <- replace_last_tensor_with_slice <- $raw_selected_param_points <- slice(1, 3, None))

    # ── Numeric channel ──
    <- (void <- { param.data = (1 - lr) * param.data + lr * grad.data } <- $select_param_points)

    # ── Symbolic channel ──
    <- ($kv_param <- $slice_view <- $param <- $kv_points)
    <- ($kv_param_grad <- $slice_view <- $param.grad <- $kv_points)
    <- (void <- $kv_param.st_patch <- $kv_param_grad)
    
    # update queries
    <- ($kv_queries
        <- Import[experience/symbolic_tensor/function/get_query_tensor.viba]
        <- $kv_param)
    <- (NestedList[($query_from_key_file_path, $query_from_value_file_path)] <- $kv_queries.st_file_paths)
    <- ($query_for_kv_content str
        <- unique
        <- sort
        <- join_with_newline
        <- Path.read_text
        <- ($query_from_key_file_path, $query_from_value_file_path))
    <- ($query_points <- replace_last_tensor_with_slice <- $raw_selected_param_points <- slice(0, 1, None))
    <- ($query_view <- $slice_view <- $param <- $query_points)
    <- (NestedList[$query_file_path str] <- $query_view.st_file_paths)
    <- (void <- write_file <- $query_file_path <- $query_for_kv_content)

zero_grad :=
    void
    <- $self StSGD
    <- $set_to_none bool # default True
    # inline
    # set_to_none=True: param.grad = None (standard torch, next backward creates fresh grad)
    # set_to_none=False: zero coefficients + reset text storage to "TODO"
    <- (void <- super().zero_grad <- $set_to_none)
    # if set_to_none=False, also reset grad text storage files to "TODO"
    <- (void <- If[not $set_to_none] <- reset_grad_text_to_todo <- $self)

# reset_grad_text_to_todo: for each param with grad, overwrite all storage files with "TODO"

# be carefull there claude code instance called in coding_agent_query.
# make sure env var CLAUDECODE unset.

