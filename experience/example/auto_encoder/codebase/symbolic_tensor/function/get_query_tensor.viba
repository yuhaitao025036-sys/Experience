QueryPromptCallable := $func ($ret str <- $task_prompt str <- $input_view_dir str <- $mutable_output_dir str)

default_prompt_for_query :=
    $prompt str
    <- $task_prompt str
    <- $input_view_dir str
    <- $mutable_output_dir str
    # inline
    <- ($prompt <- '''
        You are a semantic grep keyword generator.

        f"{task_prompt}"

        Given the symbolic tensor view in f"{input_view_dir}",
        please generate the query keywords into corresponding files in f"{mutable_output_dir}".
        Each line in an output file should contain only a single summary keyword
        that would be used for grep/query-like operations.
        The keywords of files are used for calculating similarity between files.
        All "TODO" in output files should be replaced with keywords.
        The length of keywords list should be kept small for it's a semantic summary.
    ''')

get_query_tensor :=
    $output Symbolic[torch.Tensor]
    <- $input Symbolic[torch.Tensor]
    <- $query_prompt QueryPromptCallable # default None
    <- $task_prompt str # default ""
    <- $llm_method ("coding_agent" | "raw_llm_api")
    <- $llm_env dict[str, str] # default None
    # inline
    <- $slice_tensor Import[experience/symbolic_tensor/tensor_util/slice_tensor.viba]
    <- $todo_like Import[experience/symbolic_tensor/tensor_util/todo_tensor_like.viba]
    <- ($output <- $todo_like <- $input)
    <- ($copied_output <- $slice_tensor <- $output <- Tuple[slice(None,None,None), ...]) # full sliced
    <- ($tmp_dir <- TemporaryDirectory)
    <- $dump_view Import[experience/symbolic_tensor/tensor_util/dump_view.viba]
    <- (void <- $dump_view <- $input <- f"{tmp_dir}/input_view")
    <- (void <- $dump_view <- $copied_output <- f"{tmp_dir}/mutable_output_dir")
    <- ($prompt <- ($query_prompt | default_prompt_for_query)
        <- $task_prompt
        <- f"{tmp_dir}/input_view"
        <- f"{tmp_dir}/mutable_output_dir")
    <- ($agent_task AgentTask <- $tmp_dir <- "mutable_output_dir" <- $prompt)
    <- ($all_tasks <- sole_element_list <- $agent_task)
    <- (void <- Import[experience/llm_client/task_handler.viba] <- $all_tasks <- $llm_method <- $llm_env)
    # copy back: LLM Write tool replaces symlinks with regular files,
    # so read from view files and write back to tensor storage.
    <- (void <- copy_back_to_storage_view <- f"{tmp_dir}/mutable_output_dir" <- $output)

AgentTask := Import[experience/llm_client/agent_task.viba]

# be carefull there claude code instance called in coding_agent_query.
# make sure env var CLAUDECODE unset.
