
# Prompt callable for slice_attention backward
# Callable signature type alias:
#   $func ($ret str <- $task_prompt str <- $workspace_dir str <- $const_grad_output_view str <- $const_input_view str
#          <- $const_output_view str <- $mutable_dir str)

# torch.autograd.Function backward signature:
#   backward(ctx, grad_output)
#     -> (grad_input, None, None)
# ctx saves: input, output, attention_mask,
#            grad_input_prompt, task_prompt

default_prompt_for_grad_input :=
    $prompt str
    <- $task_prompt str
    <- $workspace_dir str
    <- $const_grad_output_view str
    <- $const_input_view str
    <- $const_output_view str
    <- $mutable_grad_input_dir str
    # inline
    <- ($prompt <- '''
        You are a symbolic gradient calculator for backward pass.

        f"{task_prompt}"

        During forward pass, input elements were scattered to multiple output
        positions via attention mask. Each input[b, j] was copied to output[b, i, j]
        for every row i that attends to column j.

        Now given the output gradients (how each output copy should change),
        compute the gradient for the original input.

        Context (read-only):
        - Output gradient (text diffs at attended positions): f"{const_grad_output_view}"
        - Original input element: f"{const_input_view}"
        - Original output (copies at attended positions): f"{const_output_view}"

        Compute and write:
        1. Input gradient in f"{mutable_grad_input_dir}":
           How should the input text change, considering feedback from all
           output positions that attended to it?
        2. File f"{mutable_grad_input_dir}/<xxx>/data" must be a better version of f"{const_input_view}/<xxx>/data"

        Replace all TODO with improved source text.
    ''')

BackwardPromptCallable := $func ($ret str <- $task_prompt str <- $workspace_dir str <- $const_grad_output_view str <- $const_input_view str <- $const_output_view str <- $mutable_dir str)

slice_attention_backward :=
    $grad_input Symbolic[torch.Tensor]
    <- $grad_output Symbolic[torch.Tensor[($batch, $seq_len, $seq_len)]]
    # saved from forward ctx
    <- $input Symbolic[torch.Tensor[($batch, $seq_len)]]
    <- $output Symbolic[torch.Tensor[($batch, $seq_len, $seq_len)]]
    <- $attention_mask torch.Tensor[($batch, $seq_len, $seq_len), $dtype bool]
    <- $grad_input_prompt BackwardPromptCallable # default None
    <- $task_prompt str # default ""
    <- $llm_method ("coding_agent" | "raw_llm_api") # default raw_llm_api
    <- $llm_env dict[str, str] # default None
    <- ($grad_input <- slice_attention_backward_grad_input <- ... <- If[$input.requires_grad] <- Else[None])

slice_attention_backward_grad_input :=
    $final_grad_input Symbolic[torch.Tensor]
    <- $grad_output Symbolic[torch.Tensor[($batch, $seq_len, $seq_len)]]
    # saved from forward ctx
    <- $input Symbolic[torch.Tensor[($batch, $seq_len)]]
    <- $output Symbolic[torch.Tensor[($batch, $seq_len, $seq_len)]]
    <- $attention_mask torch.Tensor[($batch, $seq_len, $seq_len), $dtype bool]
    <- $grad_input_prompt BackwardPromptCallable # default None
    <- $task_prompt str # default ""
    <- $llm_method ("coding_agent" | "raw_llm_api") # default raw_llm_api
    <- $llm_env dict[str, str] # default None
    # inline
    <- ($grad_input
        <- Import[experience/symbolic_tensor/tensor_util/todo_tensor_like.viba]
        <- $input
        <- If[$input.requires_grad]
        <- Else[None])
    <- $slice_view Import[experience/symbolic_tensor/tensor_util/slice_view.viba]
    <- $slice_tensor Import[experience/symbolic_tensor/tensor_util/slice_tensor.viba]
    <- $dump_view Import[experience/symbolic_tensor/tensor_util/dump_view.viba]

    # ── Numeric channel (coefficient) ──
    # Forward scattered input[b,j] -> output[b,i,j] and set data to 1.0.
    # Backward gathers: grad_input[b,j] = sum_i grad_output[b,i,j] where mask[b,i,j].
    <- ($grad_input.data <- {(grad_output.data * attention_mask.float()).mean(dim=1)} <- If[$input.requires_grad])

    # ── Symbolic channel (text diff) ──
    # Transpose the forward scatter: for each input column j, find all rows that attended to it.
    <- ($input_attended_mask <- {attention_mask.any(dim=1)} <- $attention_mask)
    <- ($valid_input_points list[torch.Tensor] <- nonzero <- $input_attended_mask)
    <- (list[($batch_i int, $col_j int)] <- zip <- $valid_input_points)
    # which rows attend to column col_j
    <- (($attending_row_index_tensor, )
        <- nonzero
        <- {attention_mask[batch_i, :, col_j]})
    # slice grad_output at [batch_i, attending_rows, col_j] — 1D view of all output grads
    <- ($grad_output_view Symbolic[torch.Tensor]
        <- $slice_view
        <- $grad_output
        <- ($batch_i, $attending_row_index_tensor, $col_j))
    # slice output at same positions — original output copies
    <- ($output_view Symbolic[torch.Tensor]
        <- $slice_view
        <- $output
        <- ($batch_i, $attending_row_index_tensor, $col_j))
    # slice input at [batch_i, col_j] — single element
    <- ($input_view Symbolic[torch.Tensor]
        <- $slice_view
        <- $input
        <- ($batch_i, $col_j))
    # grad_input view (for assign back) and value (for LLM mutable dump)
    <- ($grad_input_view Symbolic[torch.Tensor]
        <- $slice_view
        <- $grad_input
        <- ($batch_i, $col_j)
        <- If[$input.requires_grad])
    <- ($grad_input_value Symbolic[torch.Tensor]
        <- $slice_tensor
        <- $grad_input
        <- ($batch_i, $col_j)
        <- If[$input.requires_grad])
    <- ($workspace_dir <- TemporaryDirectory)
    # dump const views (read-only context for LLM)
    <- (void <- $dump_view <- $grad_output_view <- f"{workspace_dir}/const_grad_output_view")
    <- (void <- $dump_view <- $input_view <- f"{workspace_dir}/const_input_view")
    <- (void <- $dump_view <- $output_view <- f"{workspace_dir}/const_output_view")
    # dump mutable view (LLM writes gradient here)
    <- (void <- $dump_view <- $grad_input_value <- f"{workspace_dir}/mutable_grad_input_dir" <- If[$input.requires_grad])
    <- ($prompt <- ($grad_input_prompt | default_prompt_for_grad_input)
        <- $task_prompt
        <- $workspace_dir
        <- f"{workspace_dir}/const_grad_output_view"
        <- f"{workspace_dir}/const_input_view"
        <- f"{workspace_dir}/const_output_view"
        <- f"{workspace_dir}/mutable_grad_input_dir")
    <- ($agent_task AgentTask <- $workspace_dir <- "mutable_grad_input_dir" <- $prompt)
    <- ($all_tasks <- list[$agent_task])
    <- (void <- Import[experience/llm_client/task_handler.viba] <- $all_tasks <- $llm_method <- $llm_env)
    <- ($diff
        <- $input_view.st_get_diff
        <- $grad_input_value)
    <- (void <- $grad_input_view.st_assign <- $diff)

AgentTask := Import[experience/llm_client/agent_task.viba]

# Numeric channel summary:
#   grad_input.data[b,j] = sum_i(grad_output.data[b,i,j] * mask[b,i,j])
#   Gradient flows back from all output positions that attended to this input.
#   This is the transpose of the forward scatter (fan-out -> fan-in/sum).
#
# Symbolic channel summary:
#   For each input element (b,j), gather all output gradients from rows
#   that attended to it (transpose of the forward attention scatter).
#   LLM sees all output diffs and writes an improved version of the input.
#
# CRITICAL: LLM Edit tool breaks symlink chains. slice_view creates
# tensor -> symlink -> parent_tensor. LLM Edit resolves first hop and
# replaces symlink with regular file. Pre-resolve with os.path.realpath
# BEFORE LLM runs to get parent's real storage path.

