

kMaskedHint := "<AUTOENCODER-CLOZE-MASK-PLACEHOLDER>"

test_baseline :=
    IterationList[$baseline_loss list[float]]
    <- $total_batch_size int # default 16
    <- $num_iterations int # default 1
    <- $llm_method str # default "raw_llm_api"
    <- $workspace_dir (str | None) # None means temp directory
    <- $interactive bool # default False, for tmux_cc mode
    <- $auto_confirm bool # default True, auto-confirm prompts in tmux
    <- $tmux_session str # default None, custom tmux session name
    #inline
    <- ($dataset_dir <- { ./codebase/ })
    <- { In most cases, operators on Symbolic[Tensor] should be symblic}
    <- (($file_path_tensor, $file_content_tensor, $ground_truth_content_tensor)
        <- Import[./parepare_dataset])
    <- (IterationList[int] <- range <- $num_iterations)
    <- ($baseline_output SymblicTensor[($total_batch_size,)]
        <- Import[./baseline_agent_model.viba].BaselineAgentModel
        <- $llm_method
        <- $interactive
        <- $auto_confirm
        <- $tmux_session)
    <- ($baseline_loss
        <- Import[function/get_edit_distance]
        <- $baseline_output
        <- $ground_truth_content_tensor)
    <- { print $baseline_output.st_uid ground_truth_content_tensor.st_uid }
