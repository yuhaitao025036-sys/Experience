
BaselineTmuxCcModel[torch.nn.Module] :=
    # forward
    $baseline_output SymbolicTensor[($total_batch_size,)]
    <- $masked_file_path_tensor Symbolic[Tensor[($total_batch_size, $num_files)]]
    <- $masked_file_content_tensor Symbolic[Tensor[($total_batch_size, $num_files)]]
    <- $llm_method str # default "tmux_cc"
    # __init__
    <- $interactive bool # default False
    <- $auto_confirm bool # default True
    <- $tmux_session str # default None
    # inline
    <- $st_stack Import[experience/symbolic_tensor/function/st_stack.viba]
    <- $merge Import[experience/symbolic_tensor/function/merge.viba]
    <- (
        $stacked_tensor Symbolic[Tensor[($total_batch_size, $num_files, 2)]]
        <- $st_stack
        <- list[$masked_file_path_tensor, $masked_file_content_tensor]
        <- $dim -1
    )
    <- (
        $path_and_contents Symbolic[Tensor[($total_batch_size, $num_files)]]
        <- $merge
        <- $stacked_tensor
        <- $axis -1
    )
    <- ($prompt str <- { Get back the original content that was masked in f"{kMaskedHint}" })
    <- (
        $baseline_output
        <- Import[experience/symbolic_tensor/function/coding_agent.viba]
        <- $path_and_contents
        <- $prompt
        <- $llm_method "tmux_cc"
        <- $interactive
        <- $auto_confirm
        <- $tmux_session
    )
