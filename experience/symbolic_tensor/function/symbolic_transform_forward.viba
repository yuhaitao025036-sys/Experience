
# Prompt callables: each is a function that receives workspace dirs and returns a prompt string.
# When None, the default is used.

default_prompt_for_output :=
    $prompt str
    <- $workspace_dir str
    <- $const_experience_view str
    <- $const_input_view str
    <- $mutable_output_dir str
    <- ($prompt <- '''
        You are a semantic translator.

        Experience mappings are defined as:
            1) file "<root_dir>/<experience_coordinate>.../0/data.xxx" means query file of <experience_coordinate>...
            2) file "<root_dir>/<experience_coordinate>.../1/data.xxx" means key file of <experience_coordinate>...
            3) file "<root_dir>/<experience_coordinate>.../2/data.xxx" means value file of <experience_coordinate>...

        You need read all the key => value pairs to get the experiences.
        The value files show the EXACT target format and syntax.
        You MUST faithfully follow the syntax patterns, structure, and style from the value files.
        Do NOT invent your own syntax or formatting — copy the patterns from the experience values.

        Conducted by f"{const_experience_view}",
        please translate source semantic text f"{const_input_view}"
        to target semantic text f"{mutable_output_dir}".

        Replace TODO in f"{mutable_output_dir}" with target semantic text.
    ''')

symbolic_transform_forward :=
    ($output Symboilc[torch.Tensor], $selected_experience_qkv_indexes_list NestList[list[torch.Tensor[int]]])
    <- $input Symboilc[torch.Tensor]
    <- $experience ExperienceTensor[Symbolic[torch.Tensor]]
    <- $output_prompt $func ($ret str <- $workspace_dir str <- $const_experience_view str <- $const_input_view str <- $mutable_output_dir str) # default None
    <- $topk int # default 16
    <- $llm_method ("coding_agent" | "raw_llm_api") # default raw_llm_api
    # inline
    <- ($output
        <- Import[experience/symbolic_tensor/tensor_util/todo_tensor_like.viba]
        <- $input)
    <- $slice_view Import[experience/symbolic_tensor/tensor_util/slice_view.viba]
    <- $slice_tensor Import[experience/symbolic_tensor/tensor_util/slice_tensor.viba]
    <- (NestList[$scalar_output_view Symbolic[torch.Tensor]] <- NestList[$slice_view] <- $output)
    <- (NestList[$scalar_output_value Symbolic[torch.Tensor]] <- NestList[$slice_tensor] <- $output)
    <- ($input_query
        <- Import[experience/symbolic_tensor/function/get_input_query_tensor.viba]
        <- $input
        <- $llm_method)
    <- (NestList[$scalar_input_view Symbolic[torch.Tensor]] <- NestList[$slice_view] <- $input)
    <- ($batch_input_file_content str <- $scalar_input_view)
    <- ($select_experience_query_indexes list[torch.Tensor[int]]
        <- Import[experience/symbolic_tensor/function/select_qkv_indexes.viba]
        <- $experience
        <- $batch_input_file_content
        <- $topk)
    <- ($selected_experience_qkv_indexes_list <- NestList[$select_experience_query_indexes])
    <- ($select_experience_indexes <- replace_last_tensor_with_full_slice <- $select_experience_query_indexes)
    <- ($experience_sliced_view ExperienceTensor[Symbolic[torch.Tensor]]
        <- $slice_view
        <- $experience
        <- $select_experience_indexes)
    <- ($workspace_dir <- TemporaryDirectory)
    <- $dump_view Import[experience/symbolic_tensor/tensor_util/dump_view.viba]
    <- (void
        <- $dump_view
        <- $experience_sliced_view
        <- f"{workspace_dir}/const_experiance_view")
    <- (void
        <- $dump_view
        <- $scalar_input_view
        <- f"{workspace_dir}/const_input_view")
    <- (void
        <- $dump_view
        <- $scalar_output_value
        <- f"{workspace_dir}/mutable_output_dir")
    <- ($prompt <- ($output_prompt | default_prompt_for_output)
        <- $workspace_dir
        <- f"{workspace_dir}/const_experiance_view"
        <- f"{workspace_dir}/const_input_view"
        <- f"{workspace_dir}/mutable_output_dir")
    <- ($agent_task AgentTask <- $workspace_dir <- "mutable_output_dir" <- $prompt)
    <- ($all_tasks <- NestList[$agent_task])
    <- (void <- Import[experience/llm_client/task_handler.viba] <- $all_tasks <- $llm_method)

    # copy back: LLM Write tool replaces symlinks with regular files,
    # so read from view files and write back to tensor storage.
    <- (void <- copy_back_to_storage_view <- f"{workspace_dir}/mutable_output_dir" <- $scalar_output_view)

AgentTask := Import[experience/llm_client/agent_task.viba]

# be carefull there claude code instance called in coding_agent_query.
# make sure env var CLAUDECODE unset.
# test both coding_agent and raw_llm_api