
# Re-export default prompt callables for public API
default_prompt_for_output := Import[experience/symbolic_tensor/function/st_moe_forward.viba].default_prompt_for_output
default_prompt_for_query := Import[experience/symbolic_tensor/function/get_query_tensor.viba].default_prompt_for_query
default_prompt_for_grad_input := Import[experience/symbolic_tensor/function/st_moe_backward.viba].default_prompt_for_grad_input
default_prompt_for_grad_exp_key := Import[experience/symbolic_tensor/function/st_moe_backward.viba].default_prompt_for_grad_exp_key
default_prompt_for_grad_exp_value := Import[experience/symbolic_tensor/function/st_moe_backward.viba].default_prompt_for_grad_exp_value
default_retrieval_method := Import[experience/symbolic_tensor/function/select_qkv_indexes.viba].default_retrieval_method

OutputPromptCallable := $func ($ret str <- $task_prompt str <- $workspace_dir str <- $const_experience_view str <- $const_input_view str <- $mutable_output_dir str)
QueryPromptCallable := Import[experience/symbolic_tensor/function/get_query_tensor.viba].QueryPromptCallable
BackwardPromptCallable := Import[experience/symbolic_tensor/function/st_moe_backward.viba].BackwardPromptCallable
RetrievalMethodCallable := Import[experience/symbolic_tensor/function/select_qkv_indexes.viba].RetrievalMethodCallable

StMoe := torch.autograd.Function[
    $forward Import[experience/symbolic_tensor/function/st_moe_forward.viba],
    $backward Import[experience/symbolic_tensor/function/st_moe_backward.viba],
    # ctx saves all prompt callables for backward
    $ctx.output_prompt OutputPromptCallable # default None
    $ctx.query_prompt QueryPromptCallable # default None
    $ctx.grad_input_prompt BackwardPromptCallable # default None
    $ctx.grad_exp_key_prompt BackwardPromptCallable # default None
    $ctx.grad_exp_value_prompt BackwardPromptCallable # default None
    $ctx.task_prompt str # default ""
    $ctx.topk int
    $ctx.retrieval_method RetrievalMethodCallable # default None
    $ctx.llm_method str
    $ctx.llm_env dict[str, str] # default None
]

st_moe := StMoe.apply

# add tests in __main__ block
