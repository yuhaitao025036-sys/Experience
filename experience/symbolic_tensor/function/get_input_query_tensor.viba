get_input_query_tensor :=
    $output Symbolic[torch.Tensor]
    <- $input Symbolic[torch.Tensor]
    <- $llm_method ("coding_agent" | "raw_llm_api")
    # inline
    <- $slice_tensor Import[experience/symbolic_tensor/tensor_util/slice_tensor.viba]
    <- $todo_like Import[experience/symbolic_tensor/tensor_util/todo_tensor_like.viba]
    <- ($output <- $todo_like <- $input)
    <- ($coped_output <- $slice_tensor <- $output <- Tuple[slice(None,None,None), ...]) # full sliced
    <- ($tmp_dir <- TemporaryDirectory)
    <- $dump_view Import[experience/symbolic_tensor/tensor_util/dump_view.viba]
    <- (void <- $dump_view <- $input <- f"{tmp_dir}/input_view")
    <- (void <- $dump_view <- $coped_output <- f"{tmp_dir}/mutable_output_dir")
    <- ($prompt str <- '''
        # please polish the following prompt
        you are a semantic grep key word generator.
        given the symbolic tensor view in f"{tmp_dir}/input_view".
        please generate the query key words into corresponding file in f"{tmp_dir}/mutable_output_dir".
        each line in a output file contains only single summary key word that used for grep/query like things.
        the key words of files are used for calucating simmularity between files.
        all "TODO" in output files should be replaced with key words.
        the length of key words list should be kept small for it's a semantic summary.
    ''')
    <- ($agent_task AgentTask <- $tmp_dir <- "mutable_output_dir" <- $prompt)
    <- ($all_tasks <- sole_element_list <- $agent_task)
    <- (void <- Import[experience/llm_client/task_handler.viba] <- $all_tasks <- $llm_method)
    # copy back: LLM Write tool replaces symlinks with regular files,
    # so read from view files and write back to tensor storage.
    <- (void <- copy_back_to_storage_view <- f"{tmp_dir}/mutable_output_dir" <- $output)

# be carefull there claude code instance called in coding_agent_query.
# make sure env var CLAUDECODE unset.
# tests should cover difference llm_method