
# Mini version of st_moe_forward: no autograd, no experience.
# Pure coding agent: input symbolic tensor → prompt → LLM → output symbolic tensor.

ForwardPromptCallable := $func ($ret str <- $task_prompt str <- $workspace_dir str <- $const_input_view str <- $mutable_output_dir str)

default_prompt_for_output :=
    $prompt str
    <- $task_prompt str
    <- $workspace_dir str
    <- $const_input_view str
    <- $mutable_output_dir str
    <- ($prompt <- '''
        You are a coding agent.

        f"{task_prompt}"

        Input: f"{const_input_view}"
        Output: f"{mutable_output_dir}"

        Replace TODO in f"{mutable_output_dir}" with result.
    ''')

coding_agent :=
    $output Symbolic[torch.Tensor[($batch_size, )]]
    <- $input Symbolic[torch.Tensor[($batch_size, $num_files)]] | Symbolic[torch.Tensor[($batch_size,)]]
    <- $output_prompt ForwardPromptCallable # default None
    <- $task_prompt str # default ""
    <- $llm_method ("coding_agent" | "raw_llm_api" | "tmux_cc") # default raw_llm_api
    <- $llm_env dict[str, str] # default None
    <- $interactive bool # default False, for tmux_cc mode
    <- $auto_confirm bool # default True, auto-confirm prompts in tmux
    <- $tmux_session str # default None, custom tmux session name
    # inline
    <- ($output Symbolic[torch.Tensor]
        <- Import[experience/symbolic_tensor/tensor_util/make_todo_tensor.viba]
        <- $shape ($batch_size, ))
    <- $slice_view Import[experience/symbolic_tensor/tensor_util/slice_view.viba]
    <- $slice_tensor Import[experience/symbolic_tensor/tensor_util/slice_tensor.viba]
    <- $dump_view Import[experience/symbolic_tensor/tensor_util/dump_view.viba]
    <- (list[$row_output_view Symbolic[torch.Tensor[(1,)]]] <- list[$slice_view] <- $output)
    <- (list[$row_output_value Symbolic[torch.Tensor[(1,)]]] <- list[$slice_tensor] <- $output)
    <- (list[$row_input_view Symbolic[torch.Tensor[(1, $num_files)]]] <- list[$slice_view] <- $input)
    <- ($workspace_dir str <- TemporaryDirectory)
    <- (void <- $dump_view <- $row_input_view <- f"{workspace_dir}/const_input_view")
    <- (void <- $dump_view <- $row_output_value <- f"{workspace_dir}/mutable_output_dir")
    <- ($prompt str <- ($output_prompt | default_prompt_for_output)
        <- $task_prompt
        <- $workspace_dir
        <- f"{workspace_dir}/const_input_view"
        <- f"{workspace_dir}/mutable_output_dir")
    <- ($agent_task AgentTask <- $workspace_dir <- "mutable_output_dir" <- $prompt)
    <- ($all_tasks list[AgentTask] <- list[$agent_task])
    <- (void <- Import[experience/llm_client/task_handler.viba]
        <- $all_tasks
        <- $llm_method
        <- $llm_env
        <- $interactive
        <- $auto_confirm
        <- $tmux_session)
    <- (void <- copy_back_to_storage_view <- f"{workspace_dir}/mutable_output_dir" <- $row_output_view)

_copy_back_to_storage_view :=
    # Copy LLM results from mutable workspace dir back through view tensor's symlinks
    void
    <- $mutable_dir str
    <- $view_tensor Symbolic[torch.Tensor]
    # inline
    <- $view_storage_path os.path.join($view_tensor.st_relative_to, $view_tensor.st_tensor_uid, "storage", "0", "data")
    <- $real_storage_path os.path.realpath($view_storage_path)
    <- $mutable_file os.path.join($mutable_dir, "data.txt")
    <- (if os.path.isfile($mutable_file): write content to $real_storage_path)

AgentTask := Import[experience/llm_client/agent_task.viba]

# test both coding_agent, raw_llm_api and tmux_cc
