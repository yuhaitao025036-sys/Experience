get_causal_attention_mask :=
    torch.Tensor[($batch_size, $seq_len, $seq_len), $dtype bool]
    <- $token_mask torch.Tensor[($batch_size, $seq_len), $dtype bool]
    <- ($tril <- { batched torch.tril } <- ($batch_size, $seq_len))
    <- ($expanded_token_mask
        <- { expand last dim to seq_len }
        <- { token_mask[:, :, None] }
        <- $token_mask)
    <- { tril & expanded_token_mask }