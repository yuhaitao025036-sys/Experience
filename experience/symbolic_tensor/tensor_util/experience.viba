ExperienceTensor := $tensor Tensor * Constraints[
        { assert $tensor.shape[-1] == 3 },
        IsCompatibleWith[Tensor, Symbolic[torch.Tensor]],
        IsQueryFile[$tensor[..., 0]],
        IsKeyFile[$tensor[..., 1]],
        IsValueFile[$tensor[..., 2]],
    ]

# There is no need to check constraints unless required explicitly.