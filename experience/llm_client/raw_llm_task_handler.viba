
AgentTask := Import[experience/llm_client/agent_task.viba]
RawLlmConfig := Import[experience/llm_client/agent_config.viba]
AgentConfigFactory := Import[experience/llm_client/agent_config_factory.viba]

RawLlmTaskHandler :=
    # Task handler for raw_llm_api method using OpenAI-compatible API
    # Now uses RawLlmConfig for configuration management
    void
    <- NestedList[$agent_task AgentTask]
    <- $llm_env dict[str, str] # Optional, for backward compatibility
    # __init__
    <- $config RawLlmConfig # Optional, default config for this handler instance
    # inline
    <- (($workspace_dir, $prompt, $output_relative_dir_or_list, $todo_file_content_hint) <- $agent_task)
    <- ($packed_workspace str
        <- Import[experience/fs_util/pack_dir.viba]
        <- $workspace_dir)
    <- (list[$output_relative_dir str] <- $output_relative_dir_or_list)
    <- (OutputFilesList[$todo_file_path str]
        <- grep_by_file_content_hint
        <- $root_dir f"{workspace_dir}/{output_relative_dir}"
        <- $todo_file_content_hint)
    # Configuration priority: runtime llm_env > constructor config > factory default
    <- $effective_config {
        if llm_env: convert llm_env to RawLlmConfig
        elif self.default_config: use self.default_config
        else: AgentConfigFactory.create_raw_llm_config()
    }
    <- ($raw_llm_prompt_template str <- '''
        {prompt}

        === WORKSPACE CONTENT ===
        {packed_workspace}
        === END WORKSPACE ===

        Based on the code context above, output the missing source code that should replace the placeholder.
        Output ONLY the raw source code. No markdown code fences. No explanations.
    ''')
    <- $raw_llm_query Import[experience/llm_client/raw_llm_query.py]
    <- $async_do_for_one_batch (
        str
        <- $raw_llm_query
        <- $raw_llm_prompt_template
        <- $effective_config)
    <- (NestList[OutputFilesList[$output_file_content str]]
        <- async_gather_run
        <- NestList[OutputFilesList[$async_do_for_one_batch]])
    <- (void
        <- save_file
        <- $todo_file_path
        <- $output_file_content)
