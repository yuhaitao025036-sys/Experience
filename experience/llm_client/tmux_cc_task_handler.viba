
TmuxCcTaskHandler :=
    # Use tmux_cc (ducc) CLI to process agent tasks
    # Supports interactive tmux mode for visual observation or subprocess mode for batch processing
    void
    <- NestedList[$agent_task Import[experience/llm_client/agent_task.viba]]
    <- $llm_env dict[str, str] # default None
    <- $interactive bool # default False
    <- $auto_confirm bool # default True
    <- $tmux_session str # default None
    <- ()
    # Pipeline:
    # 1. Find the tmux_cc binary from environment or default paths
    <- $tmux_cc_bin { search TMUX_CC_BIN env, then PATH, then ~/.comate/extensions/ }
    # 2. Prepare workspace root directory
    <- $workspace_root { use TMUX_CC_WORKSPACE_ROOT env or default ~/.tmux_cc_tmp/ }
    # 3. For each task, create isolated workspace with input/output directories
    <- $task_workspace { create task dir with input/prompt.txt, input/packed_workspace.txt, output/ }
    # 4. Build file-based prompt that tells ducc to read from workspace files
    <- $file_based_prompt { instruct ducc to read from input/ and write to output/result.txt }
    # 5. Run tmux_cc in interactive tmux mode or subprocess mode
    <- $run_mode { "tmux" if interactive else "subprocess" }
    <- { batch run all tasks using tmux_cc_bin with file_based_prompt }
    # 6. Copy results back from workspace to original directory
    <- { copy output from task_workspace to original workspace_dir }
