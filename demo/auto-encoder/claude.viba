

kMaskedHint := "<AUTOENCODER-CLOZE-MASK-PLACEHOLDER>"

task_description :=
    void
    <- $total_batch_size int # default 16
    <- $workspace_dir (str | None) # None means temp directory
    #inline
    <- { change to a git worktree of current Experience repo }
    <- { In most cases, operators on Symbolic[Tensor] should be symblic}
    <- (($file_path_tensor, $file_content_tensor, $ground_truth_content_tensor)
        <- PrepareDataSet)
    <- ($baseline_output SymblicTensor[($total_batch_size,)]
        <- BaselineCodingAgentModel)
    <- ($baseline_loss
        <- Import[function/get_edit_distance]
        <- $baseline_output
        <- $ground_truth_content_tensor)
    <- { print $baseline_output.st_uid ground_truth_content_tensor.st_uid }

BaselineCodingAgentModel[torch.nn.Module] :=
    $baseline_output SymblicTensor[($total_batch_size,)]
    <- $masked_file_path_tensor Symbolic[Tensor[($total_batch_size, $num_files)]]
    <- $masked_file_content_tensor Symbolic[TensorTensor[($total_batch_size, $num_files)]]
    <- $ground_truth_content_tensor Symbolic[TensorTensor[($total_batch_size)]]
    #inline
    <- (
        $path_and_contents Symbolic[Tensor[($total_batch_size, $num_files)]]
        <- Import[function/merge]
        <- { concat on last axis }
        <- $masked_file_path_tensor
        <- $masked_file_content_tensor
    )
    <- (
        $merged_path_and_contents Symbolic[Tensor[($total_batch_size,)]]
        <- { fetch last column }
        <- Import[function/st_attention]
        <- { prepare special attention mask to concat prefixes to last column }
        <- $path_and_contents
    )
    <- ($prompt <- { autoencoder prompt for baseline model })
    <- (
        $baseline_output 
        <- Import[function/coding_agent.viba]
        <- $merged_path_and_contents
        <- $prompt
        <- $llm_method "raw_llm_api"
    )

PrepareDataSet := 
    (
        $masked_file_path_tensor Symbolic[Tensor[($total_batch_size, $num_files)]],
        $masked_file_content_tensor Symbolic[TensorTensor[($total_batch_size, $num_files)]],
        $ground_truth_content_tensor Symbolic[TensorTensor[($total_batch_size)]]
    )
    <- $total_batch_size int
    <- $dataset_dir
    # inline
    <- ($files list[($file_path str, $file_content)] <- {
        fetch all files in experience/ 
    })
    <- {num_files = len(files)}
    <- ((
           $file_path_tensor Symbolic[Tensor(1, $num_files)],
           $file_content_tensor Symbolic[Tensor(1, $num_files)]
        )
        <- unzip
        <- $relative_to ($dataset_dir)
        <- list[($file_path str, $file_content)])
    <- (list[($random_file_index int, $random_range_line_start int, $random_range_line_end int)]
        <- {
            get multiple random ranges
            skip comments lines and code in __main__ block
            the range size should be in range (20, 30)
        }
        <- $total_batch_size
        <- $num_files)
    <- ((
            $sole_masked_file_path_tensor Symbolic[Tensor(1, $num_files)], 
            $sole_masked_file_content_tensor Symbolic[Tensor(1, $num_files)], 
            $sole_ground_truth_content_tensor Symbolic[Tensor(1,)]
        )
        <- {
            copy file $random_file_index
            mask ($random_range_line_start, $random_range_line_end) with kMaskedHint
        }
        <- slice_view
        <- $file_path_tensor
        <- $file_content_tensor)
    <- ($masked_file_path_tensor <- list[$sole_masked_file_path_tensor])
    <- ($masked_file_content_tensor <- list[$sole_masked_file_content_tensor])
    <- ($ground_truth_content_tensor <- list[$sole_ground_truth_content_tensor])
