
# Prompt is only for comprehension. do not generate
Prompt := str

# SymbolicSGD extends torch.optim.Optimizer
# Two-channel update: numeric coefficient SGD + symbolic text diff via LLM
#
# Usage:
#   optimizer = SymbolicSGD([experience_tensor], lr=0.01)
#   optimizer.zero_grad()
#   ... forward / backward ...
#   optimizer.step()

SymbolicSGD := torch.optim.Optimizer

__init__ :=
    void
    <- $self SymbolicSGD
    <- $params ParamsT
    <- $lr float # default 0.01    # inline
    <- (void <- super().__init__ <- $params <- dict[lr=$lr])

step :=
    void
    <- $self SymbolicSGD
    <- $closure Optional[Callable] # default None
    # inline
    <- $slice_view Import[symbolic_tensor/tensor_util/slice_view.viba]
    <- $slice_tensor Import[symbolic_tensor/tensor_util/slice_tensor.viba]
    <- $dump_view Import[symbolic_tensor/tensor_util/dump_view.viba]

    # for each param_group, for each param with grad:
    <- ($lr float <- $param_group['lr'])
    <- (list[$param Symbolic[torch.Tensor]] <- $param_group['params'])
    <- (list[$grad Symbolic[torch.Tensor]] <- $param.grad)

    # ── Numeric channel ──
    <- (void <- '''param.data = (1 - lr) * param.data + lr * grad.data''')

    # ── Symbolic channel ──
    <- (list[$storage_elem_file_ralative_path str] <- $param)
    <- ($param_storage_root_dir str <- $param.st_relative_to <- $param.st_tensor_uid)
    <- ($grad_storage_root_dir str <- $grad.st_relative_to <- $grad.st_tensor_uid)
    <- ($param_elem_file_ralative_path str <- $param_storage_root_dir <- $storage_elem_file_ralative_path)
    <- ($grad_elem_file_ralative_path str <- $grad_storage_root_dir <- $storage_elem_file_ralative_path)
    <- (void <- remove_rej_file <- f"{param_elem_file_ralative_path}.rej")
    <- (void <- '''patch --no-backup-if-mismatch --fuzz=3 -i {grad_elem_file_ralative_path} {param_elem_file_ralative_path}''')


zero_grad :=
    void
    <- $self SymbolicSGD
    <- $set_to_none bool # default True
    # inline
    # set_to_none=True: param.grad = None (standard torch, next backward creates fresh grad)
    # set_to_none=False: zero coefficients + reset text storage to "TODO"
    <- (void <- super().zero_grad <- $set_to_none)
    # if set_to_none=False, also reset grad text storage files to "TODO"
    <- (void <- If[not $set_to_none] <- reset_grad_text_to_todo <- $self)

# reset_grad_text_to_todo: for each param with grad, overwrite all storage files with "TODO"

# be carefull there claude code instance called in coding_agent_query.
# make sure env var CLAUDECODE unset.

